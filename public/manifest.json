{
  "manifest_version": 3,
  "name": "Slop Pacer",
  "description": "Combined month-to-date usage for Claude, ChatGPT, and Cursor.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/fire-16.png",
    "32": "icons/fire-32.png",
    "48": "icons/fire-48.png",
    "128": "icons/fire-128.png"
  },
  "minimum_chrome_version": "120",
  "permissions": ["alarms", "storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://cursor.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*", "https://chatgpt.com/*", "https://cursor.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Slop Pacer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/fire-16.png",
      "32": "icons/fire-32.png"
    }
  }
}
